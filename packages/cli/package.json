{
  "name": "openquick",
  "version": "0.1.0",
  "description": "Self-hosted Shopify-Quick-style instant sites on your own Cloudflare account: folder in, URL out, with a zero-config database, realtime, files and AI API.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "oquick": "dist/oquick.cjs"
  },
  "files": [
    "dist",
    "platform",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "tsc"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "hosting",
    "quick",
    "static-site",
    "durable-objects"
  ],
  "dependencies": {
    "wrangler": "4.97.0"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "esbuild": "0.25.5",
    "typescript": "5.8.3"
  }
}
